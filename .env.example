# Configuración de Supabase
SUPABASE_URL=tu_url_de_supabase_aqui
SUPABASE_KEY=tu_api_key_de_supabase_aqui

# Configuración de TuBondi API
TUBONDI_API_URL=https://api.tubondi.com/endpoint
# Agregar otros endpoints de TuBondi según sea necesario

# Configuración del cronjob (opcional)
CRON_SCHEDULE=*/2 * * * *

# Configuración de logs
LOG_LEVEL=info